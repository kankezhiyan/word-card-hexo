<div class="cat-box">
    <div class="cat-title">年份：</div>
    <div class="cat-list">
        <% 
        let years = {}
        site.posts.each(function(post) {
            let year = post.date.year()
            if (!years[year]) years[year] = 0
            years[year]++
        }) %>
        <% Object.keys(years).sort().reverse().forEach(function(year) { %>
            <div class="cat-item">
                <a href="<%- url_for('archives/' + year) %>"><%= year %>(<%= years[year] %>)</a>
            </div>
        <% }) %>
    </div>
</div>
<% 
var lastYear,
    lastMonth,
    currentYear,
    currentMonth
%>
<section class="archive-list">
    <% page.posts.sort('date', 'desc').each(function(post) { %>
        <% 
            currentYear = post.date.year()
            currentMonth = post.date.format('MM')
        %>
        <% if (currentYear != lastYear) { %>
            <% if (lastYear != null) { %>
                <% lastMonth = null %>
                </section>
                <section class="archive-list">
            <% } %>
            <h3 class="archive-year">
                <a class="archive-sub" href="<%- url_for('archives/' + currentYear) %>"><%= currentYear %></a>
            </h3>
            <% lastYear = currentYear %>
        <% } %>
        <% if (currentMonth != lastMonth) { %>
            <% if (lastMonth != null) { %>
            </ul>  
            <% } %>
            <h4 class="archive-month">
                <a class="archive-sub" href="<%- url_for('archives/' + post.date.format('YYYY/MM')) %>"><%= currentMonth %>月</a>
            </h4>
            <% lastMonth = currentMonth %>
            <ul class="archive timeline">
        <% } %>
        <li>
            <span class="archive-date"><%= date(post.date, "YY.MM.DD") %></span>
            <div class="archive-main">
                <a class="archive-title" href="<%- url_for(post.path) %>"><%= post.title %></a>
                <a class="archive-info" href="<%- url_for(post.categories.data[0].path) %>">
                    <%= post.categories.data[0].name %>
                </a>
                <a class="archive-info" href="<%- url_for(post.tags.data[0].path) %>">
                    <%= post.tags.data[0].name %>
                </a>
            </div>
        </li>
    <% }) %>
</section>
<%- include('_partial/paginator') %>